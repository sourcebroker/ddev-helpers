#!/bin/bash

TEXT_RED=$(tput setaf 1)
TEXT_RESET=$(tput sgr0)

if [ -e composer.json ] && [ ! -e vendor ]; then
  composer install
fi

curl -LsSf https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL="$HOME/bin" sh

if [ -d "/var/www/html/.agents-tooling" ]; then cd /var/www/html/.agents-tooling && composer update ; fi
